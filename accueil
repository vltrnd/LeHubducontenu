<html lang="fr">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>La Régie — Aeconomia</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Plus+Jakarta+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;1,400;1,700&display=swap" rel="stylesheet"/>
<style>
*{box-sizing:border-box;margin:0;padding:0;}
:root{
  --bg:#0e0e0d;--bg2:#161614;--bg3:#1e1d1b;
  --ow:#F5F3EF;--beige:#c2b8ae;--beige2:#e2dfd6;
  --sage:#89a596;--sage-dim:rgba(137,165,150,.12);--sage-border:rgba(137,165,150,.22);
  --muted:rgba(245,243,239,.42);--border:rgba(245,243,239,.07);
  --card:rgba(245,243,239,.04);--card2:rgba(245,243,239,.08);
}
html{scroll-behavior:smooth;}
body{font-family:'Plus Jakarta Sans',sans-serif;background:var(--bg);color:var(--ow);overflow-x:hidden;-webkit-font-smoothing:antialiased;}
::selection{background:rgba(137,165,150,.28);}
a{text-decoration:none;color:inherit;}

/* NAV */
nav{position:fixed;top:0;left:0;right:0;z-index:200;padding:.95rem 2.5rem;display:flex;justify-content:space-between;align-items:center;background:rgba(14,14,13,.88);backdrop-filter:blur(24px);border-bottom:1px solid var(--border);}
.logo{font-family:'Space Grotesk',sans-serif;font-size:.9rem;font-weight:700;color:var(--ow);letter-spacing:-.2px;}
.logo em{color:var(--sage);font-style:normal;}
.nav-links{display:flex;gap:2.2rem;}
.nav-links a{font-family:'Space Grotesk',sans-serif;font-size:.6rem;font-weight:500;color:var(--muted);letter-spacing:.09em;text-transform:uppercase;transition:color .2s;position:relative;}
.nav-links a::after{content:'';position:absolute;bottom:-2px;left:0;width:0;height:1px;background:var(--sage);transition:width .3s;}
.nav-links a:hover{color:var(--ow);}
.nav-links a:hover::after{width:100%;}
.nav-badge{display:flex;align-items:center;gap:.5rem;}
.live-dot{width:6px;height:6px;border-radius:50%;background:var(--sage);animation:pulse-dot 2s infinite;}
.live-txt{font-family:'Space Grotesk',sans-serif;font-size:.58rem;font-weight:600;color:var(--sage);}

/* HERO */
.hero{min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:8rem 2.5rem 5rem;position:relative;overflow:hidden;}
.hero-glow{position:absolute;top:30%;left:50%;transform:translate(-50%,-50%);width:700px;height:500px;background:radial-gradient(ellipse,rgba(137,165,150,.06) 0%,transparent 65%);pointer-events:none;}
.hero-grid{position:absolute;inset:0;background-image:linear-gradient(var(--border) 1px,transparent 1px),linear-gradient(90deg,var(--border) 1px,transparent 1px);background-size:72px 72px;pointer-events:none;}
.hero-inner{max-width:820px;text-align:center;position:relative;z-index:1;}
.eyebrow{display:inline-flex;align-items:center;gap:.5rem;font-family:'Space Grotesk',sans-serif;font-size:.58rem;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:var(--sage);background:var(--sage-dim);border:1px solid var(--sage-border);border-radius:50px;padding:5px 14px;margin-bottom:1.6rem;}
.eyebrow-dot{width:5px;height:5px;border-radius:50%;background:var(--sage);animation:pulse-dot 2s infinite;}
h1{font-family:'Space Grotesk',sans-serif;font-size:clamp(2.8rem,5.5vw,4.8rem);font-weight:700;letter-spacing:-2.5px;line-height:.93;margin-bottom:1.2rem;}
h1 em{font-family:'Plus Jakarta Sans',sans-serif;font-style:italic;font-weight:800;color:var(--sage);}
.hero-sub{font-size:.95rem;color:var(--muted);max-width:500px;margin:0 auto 2.5rem;line-height:1.8;}
.cta-row{display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;margin-bottom:3.5rem;}

/* BUTTONS */
.btn{font-family:'Space Grotesk',sans-serif;font-weight:700;border:none;border-radius:13px;cursor:pointer;display:inline-flex;align-items:center;gap:9px;transition:all .25s;position:relative;overflow:hidden;}
.btn-sage{font-size:.82rem;padding:14px 26px;background:var(--sage);color:#fff;}
.btn-sage:hover{transform:translateY(-2px);box-shadow:0 14px 36px rgba(137,165,150,.28);}
.btn-ghost{font-size:.82rem;padding:14px 26px;background:var(--card2);color:var(--ow);border:1px solid var(--border);}
.btn-ghost:hover{background:var(--bg3);border-color:rgba(245,243,239,.14);transform:translateY(-2px);}
.btn-sm{font-size:.72rem;padding:10px 18px;}
.bi{width:20px;height:20px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:.58rem;flex-shrink:0;}
.bi-white{background:rgba(255,255,255,.18);}
.bi-dark{background:var(--card2);}

/* STATS BAR */
.stats-bar{display:grid;grid-template-columns:repeat(4,1fr);background:var(--bg2);border:1px solid var(--border);border-radius:18px;overflow:hidden;width:100%;}
.stat-item{padding:1.4rem 1rem;text-align:center;border-right:1px solid var(--border);}
.stat-item:last-child{border-right:none;}
.stat-n{font-family:'Space Grotesk',sans-serif;font-size:1.9rem;font-weight:700;letter-spacing:-1.5px;color:var(--ow);line-height:1;}
.stat-n em{color:var(--sage);font-style:normal;}
.stat-l{font-size:.62rem;color:var(--muted);margin-top:.3rem;line-height:1.45;}

/* SECTION WRAPPER */
.wrap{max-width:1080px;margin:0 auto;padding:5rem 2.5rem;}
.sec-tag{font-family:'Space Grotesk',sans-serif;font-size:.56rem;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:var(--sage);margin-bottom:.65rem;}
.sec-h2{font-family:'Space Grotesk',sans-serif;font-size:clamp(1.6rem,2.8vw,2.3rem);font-weight:700;letter-spacing:-1px;line-height:1.05;}
.sec-h2 em{font-family:'Plus Jakarta Sans',sans-serif;font-style:italic;font-weight:800;color:var(--sage);}
.sec-sub{font-size:.85rem;color:var(--muted);line-height:1.75;max-width:480px;margin-top:.6rem;}

.divider{height:1px;background:var(--border);max-width:1080px;margin:0 auto;}

/* IMPACT GRID */
.impact-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:.9rem;margin-top:2.5rem;}
.impact-card{background:var(--bg2);border:1px solid var(--border);border-radius:20px;padding:1.5rem;transition:all .3s;}
.impact-card:hover{border-color:var(--sage-border);background:var(--bg3);transform:translateY(-3px);}
.impact-n{font-family:'Space Grotesk',sans-serif;font-size:2rem;font-weight:700;letter-spacing:-1.5px;color:var(--sage);line-height:1;margin-bottom:.4rem;}
.impact-t{font-family:'Space Grotesk',sans-serif;font-size:.8rem;font-weight:700;color:var(--ow);margin-bottom:.4rem;}
.impact-d{font-size:.7rem;color:var(--muted);line-height:1.65;}
.impact-when{font-family:'Space Grotesk',sans-serif;font-size:.52rem;font-weight:600;letter-spacing:.07em;text-transform:uppercase;color:var(--beige);margin-top:.8rem;padding-top:.7rem;border-top:1px solid var(--border);}

/* PREVIEW DEUX PAGES */
.pages-grid{display:grid;grid-template-columns:1fr 1fr;gap:1.2rem;margin-top:2.5rem;}
.page-card{background:var(--bg2);border:1px solid var(--border);border-radius:24px;overflow:hidden;transition:all .35s cubic-bezier(.22,1,.36,1);}
.page-card:hover{border-color:var(--sage-border);transform:translateY(-4px);box-shadow:0 24px 60px rgba(0,0,0,.35);}
.page-card-top{padding:2rem;}
.page-card-emoji{font-size:1.6rem;margin-bottom:1rem;}
.page-card h3{font-family:'Space Grotesk',sans-serif;font-size:1.1rem;font-weight:700;letter-spacing:-.3px;margin-bottom:.5rem;}
.page-card p{font-size:.75rem;color:var(--muted);line-height:1.65;margin-bottom:1.2rem;}
.page-card-pills{display:flex;flex-wrap:wrap;gap:.35rem;margin-bottom:1.5rem;}
.tag-pill{font-family:'Space Grotesk',sans-serif;font-size:.52rem;font-weight:600;letter-spacing:.04em;padding:3px 9px;border-radius:50px;background:var(--card2);color:var(--muted);border:1px solid var(--border);}
.tag-pill.g{background:var(--sage-dim);color:var(--sage);border-color:var(--sage-border);}
.page-card-mini{display:grid;grid-template-columns:1fr 1fr;gap:.5rem;padding:0 2rem 1.5rem;}
.mini-card{background:var(--bg3);border:1px solid var(--border);border-radius:11px;padding:.75rem;}
.mini-card-tag{font-family:'Space Grotesk',sans-serif;font-size:.48rem;font-weight:600;letter-spacing:.04em;color:var(--sage);background:var(--sage-dim);border-radius:50px;padding:2px 7px;display:inline-block;margin-bottom:.3rem;}
.mini-card-t{font-family:'Space Grotesk',sans-serif;font-size:.65rem;font-weight:600;color:var(--ow);margin-bottom:.15rem;}
.mini-card-s{font-size:.58rem;color:var(--muted);}
.page-card-footer{padding:1.1rem 2rem;border-top:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;}
.card-cta{font-family:'Space Grotesk',sans-serif;font-size:.7rem;font-weight:700;color:var(--sage);display:flex;align-items:center;gap:.3rem;transition:gap .2s;}
.page-card:hover .card-cta{gap:.6rem;}

/* ACADEMY PREVIEW */
.academy-wrap{display:grid;grid-template-columns:1fr 1fr;gap:2.5rem;align-items:center;margin-top:2.5rem;background:var(--bg2);border:1px solid var(--border);border-radius:24px;padding:2.5rem;overflow:hidden;}
.academy-modules{display:flex;flex-direction:column;gap:.55rem;}
.mod{background:var(--bg3);border:1px solid var(--border);border-radius:13px;padding:.85rem 1rem;display:flex;align-items:center;gap:.8rem;transition:all .25s;}
.mod:hover{border-color:var(--sage-border);transform:translateX(4px);}
.mod-icon{width:34px;height:34px;border-radius:9px;background:var(--sage-dim);border:1px solid var(--sage-border);display:flex;align-items:center;justify-content:center;font-size:.85rem;flex-shrink:0;}
.mod-t{font-family:'Space Grotesk',sans-serif;font-size:.72rem;font-weight:600;color:var(--ow);}
.mod-s{font-size:.6rem;color:var(--muted);}
.mod-badge{font-family:'Space Grotesk',sans-serif;font-size:.48rem;font-weight:600;background:var(--sage-dim);color:var(--sage);border:1px solid var(--sage-border);border-radius:50px;padding:2px 8px;margin-left:auto;flex-shrink:0;white-space:nowrap;}

/* FOOTER */
footer{border-top:1px solid var(--border);padding:1.8rem 2.5rem;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:1rem;}
.foot-logo{font-family:'Space Grotesk',sans-serif;font-size:.85rem;font-weight:700;}
.foot-logo em{color:var(--sage);font-style:normal;}
.foot-copy{font-size:.6rem;color:var(--muted);}

/* ANIMATIONS */
@keyframes pulse-dot{0%,100%{box-shadow:0 0 0 0 rgba(137,165,150,.5)}70%{box-shadow:0 0 0 6px rgba(137,165,150,0)}}
@keyframes fadeUp{from{opacity:0;transform:translateY(22px)}to{opacity:1;transform:translateY(0)}}
.fu{opacity:0;animation:fadeUp .7s cubic-bezier(.22,1,.36,1) forwards;}
.d1{animation-delay:.08s}.d2{animation-delay:.16s}.d3{animation-delay:.24s}.d4{animation-delay:.32s}.d5{animation-delay:.4s}
.reveal{opacity:0;transform:translateY(18px);transition:opacity .65s cubic-bezier(.22,1,.36,1),transform .65s cubic-bezier(.22,1,.36,1);}
.reveal.on{opacity:1;transform:translateY(0);}
</style>
</head>
